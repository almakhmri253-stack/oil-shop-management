@model OilShopManagement.ViewModels.SalesReportViewModel
@{
    ViewData["Title"] = L.T("تقرير المبيعات","Sales Report");
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-bar-chart me-2 text-primary"></i>@L.T("تقرير المبيعات","Sales Report")</h4>
    <button onclick="window.print()" class="btn btn-outline-primary rounded-pill btn-sm no-print">
        <i class="bi bi-printer me-1"></i>@L.T("طباعة","Print")
    </button>
</div>

<div class="card mb-3 no-print">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-semibold">@L.T("من تاريخ","From")</label>
                <input type="date" name="from" class="form-control" value="@Model.FromDate.ToString("yyyy-MM-dd")">
            </div>
            <div class="col-md-4">
                <label class="form-label small fw-semibold">@L.T("إلى تاريخ","To")</label>
                <input type="date" name="to" class="form-control" value="@Model.ToDate.ToString("yyyy-MM-dd")">
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search me-1"></i>@L.T("عرض التقرير","Show Report")
                </button>
            </div>
        </form>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="stat-card" style="background:linear-gradient(135deg,#0d6efd,#6ea8fe);color:#fff">
            <div class="stat-icon" style="background:rgba(255,255,255,0.2)"><i class="bi bi-receipt-cutoff"></i></div>
            <div class="stat-value">@Model.TotalInvoices</div>
            <div class="stat-label">@L.T("إجمالي الفواتير","Total Invoices")</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card" style="background:linear-gradient(135deg,#198754,#75b798);color:#fff">
            <div class="stat-icon" style="background:rgba(255,255,255,0.2)"><i class="bi bi-cash-stack"></i></div>
            <div class="stat-value" style="font-size:1.2rem">@Model.TotalSales.ToString("N3")</div>
            <div class="stat-label">@L.T("إجمالي المبيعات (ر.ع.)","Total Sales (OMR)")</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card" style="background:linear-gradient(135deg,#ffc107,#ffda6a);color:#000">
            <div class="stat-icon" style="background:rgba(0,0,0,0.1)"><i class="bi bi-graph-up-arrow"></i></div>
            <div class="stat-value" style="font-size:1.2rem">@Model.TotalProfit.ToString("N3")</div>
            <div class="stat-label">@L.T("إجمالي الأرباح (ر.ع.)","Total Profit (OMR)")</div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        @L.T("الفواتير من","Invoices from") @Model.FromDate.ToString("dd/MM/yyyy HH:mm") @L.T("إلى","to") @Model.ToDate.ToString("dd/MM/yyyy HH:mm")
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>@L.T("رقم الفاتورة","Invoice #")</th>
                        <th>@L.T("العميل","Customer")</th>
                        <th>@L.T("التاريخ","Date")</th>
                        <th>@L.T("الإجمالي","Subtotal")</th>
                        <th>@L.T("الضريبة","Tax")</th>
                        <th>@L.T("الصافي","Net")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var inv in Model.Invoices)
                    {
                        <tr>
                            <td>@inv.InvoiceNumber</td>
                            <td>@(inv.Customer?.Name ?? L.T("عميل عام","Walk-in"))</td>
                            <td>@inv.InvoiceDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@inv.SubTotal.ToString("N3")</td>
                            <td>@inv.TaxAmount.ToString("N3")</td>
                            <td class="fw-semibold text-primary">@inv.TotalAmount.ToString("N3")</td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-primary">
                    <tr>
                        <td colspan="5" class="fw-bold">@L.T("الإجمالي","Total")</td>
                        <td class="fw-bold">@Model.TotalSales.ToString("N3") @L.T("ر.ع.","OMR")</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>
