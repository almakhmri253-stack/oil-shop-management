@model OilShopManagement.ViewModels.InvoiceCreateViewModel
@{
    ViewData["Title"] = "فاتورة جديدة";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h4 class="fw-bold mb-0"><i class="bi bi-plus-circle me-2 text-primary"></i>فاتورة جديدة</h4>
    <a href="/Invoices" class="btn btn-outline-secondary rounded-pill btn-sm">
        <i class="bi bi-arrow-right me-1"></i>الفواتير
    </a>
</div>

<div class="invoice-builder">
    <!-- Left: Items -->
    <div>
        <!-- Product Search -->
        <div class="card mb-3">
            <div class="card-header">
                <i class="bi bi-search me-2 text-primary"></i>إضافة منتج
            </div>
            <div class="card-body">
                <div class="product-search-box">
                    <input type="text" id="productSearch" class="form-control form-control-lg"
                        placeholder="ابحث باسم المنتج أو الرمز..."
                        autocomplete="off">
                    <div id="productSuggestions" class="product-suggestions d-none"></div>
                </div>
            </div>
        </div>

        <!-- Available Products Browser -->
        <div class="card mb-3">
            <div class="card-header d-flex align-items-center justify-content-between py-2"
                 style="cursor:pointer" onclick="toggleProductBrowser()">
                <span><i class="bi bi-grid me-2 text-success"></i>المنتجات المتوفرة</span>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge bg-success-subtle text-success rounded-pill" id="inStockCount">...</span>
                    <i class="bi bi-chevron-down" id="browserChevron"></i>
                </div>
            </div>
            <div id="productBrowser" class="card-body p-2">
                <input type="text" id="browserFilter" class="form-control form-control-sm mb-2"
                    placeholder="فلتر المنتجات..." oninput="filterBrowser(this.value)">
                <div id="productGrid" class="d-flex flex-wrap gap-2" style="max-height:220px;overflow-y:auto"></div>
            </div>
        </div>

        <!-- Items Table -->
        <div class="card">
            <div class="card-header d-flex align-items-center justify-content-between">
                <span><i class="bi bi-list-check me-2"></i>المنتجات</span>
                <span class="badge bg-primary rounded-pill" id="itemCount">0 منتج</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table mb-0" id="itemsTable">
                        <thead>
                            <tr>
                                <th>المنتج</th>
                                <th style="width:110px">الكمية</th>
                                <th style="width:130px">السعر</th>
                                <th style="width:130px">الإجمالي</th>
                                <th style="width:50px"></th>
                            </tr>
                        </thead>
                        <tbody id="itemsBody">
                            <tr id="emptyRow">
                                <td colspan="5" class="text-center text-muted py-5">
                                    <i class="bi bi-cart-x fs-2 d-block mb-2"></i>
                                    ابحث عن منتج وأضفه للفاتورة
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: Summary -->
    <div>
        <div class="invoice-summary card">
            <div class="card-header fw-bold">
                <i class="bi bi-receipt me-2 text-primary"></i>ملخص الفاتورة
            </div>
            <div class="card-body">
                <!-- Customer -->
                <div class="mb-3">
                    <label class="form-label fw-semibold small">العميل (اختياري)</label>
                    <div class="input-group">
                        <input type="text" id="customerSearch" class="form-control form-control-sm" placeholder="اسم العميل أو الجوال...">
                        <button class="btn btn-outline-secondary btn-sm" type="button" id="clearCustomer" title="مسح">
                            <i class="bi bi-x"></i>
                        </button>
                    </div>
                    <div id="customerSuggestions" class="product-suggestions d-none"></div>
                    <input type="hidden" id="selectedCustomerId">
                    <div id="selectedCustomerInfo" class="mt-2 small text-success d-none"></div>
                </div>

                <!-- Date & Payment -->
                <div class="mb-3">
                    <label class="form-label fw-semibold small">تاريخ الفاتورة</label>
                    <input type="datetime-local" id="invoiceDate" class="form-control form-control-sm"
                        value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm", System.Globalization.CultureInfo.InvariantCulture)">
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small">طريقة الدفع</label>
                    <select id="paymentMethod" class="form-select form-select-sm">
                        <option value="0">نقداً</option>
                        <option value="1">بطاقة</option>
                        <option value="2">تحويل</option>
                    </select>
                </div>

                <hr>
                <!-- Totals -->
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="text-muted">الإجمالي قبل الضريبة</span>
                    <input type="number" id="subTotal" class="form-control form-control-sm text-end fw-semibold"
                        style="width:120px" min="0" step="0.001" value="0" placeholder="0.000">
                </div>
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="text-muted">الضريبة
                        <input type="number" id="taxRate" value="15" min="0" max="100"
                            class="form-control form-control-sm d-inline-block ms-1" style="width:55px">%
                    </span>
                    <span id="taxAmount" class="fw-semibold">0.00</span>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="text-muted">خصم (ر.ع.)</span>
                    <input type="number" id="discount" value="0" min="0"
                        class="form-control form-control-sm text-end" style="width:100px">
                </div>
                <hr>
                <div class="d-flex justify-content-between mb-3">
                    <span class="fw-bold fs-5">الإجمالي النهائي</span>
                    <span id="totalAmount" class="fw-bold fs-5 text-primary">0.00 ر.ع.</span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold small">ملاحظات</label>
                    <textarea id="notes" class="form-control form-control-sm" rows="2" placeholder="ملاحظات..."></textarea>
                </div>

                <button type="button" id="saveInvoice" class="btn btn-primary w-100 btn-lg rounded-pill" disabled>
                    <i class="bi bi-save2 me-2"></i>حفظ الفاتورة
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
let invoiceItems = [];
let allProducts = [];
fetch('/Products/GetAllJson').then(r => r.json()).then(d => {
    allProducts = d;
    renderProductBrowser(d);
}).catch(() => {});

let browserProducts = [];

function getDisplayStock(p) {
    const isCarton = (p.unit === 'كرتون' || p.unit === 'Carton') && p.piecesPerUnit > 0;
    return isCarton
        ? { displayStock: (p.currentStock * p.piecesPerUnit) + ' حبة', displayUnit: 'كرتون (' + p.piecesPerUnit + ' حبة)' }
        : { displayStock: p.currentStock + ' ' + p.unit, displayUnit: p.unit };
}

function renderProductBrowser(products) {
    browserProducts = products.filter(p => p.currentStock > 0);
    document.getElementById('inStockCount').textContent = browserProducts.length + ' صنف';
    const grid = document.getElementById('productGrid');
    if (!browserProducts.length) {
        grid.innerHTML = '<div class="text-muted small p-2">لا توجد منتجات متوفرة</div>';
        return;
    }
    grid.innerHTML = browserProducts.map((p, idx) => {
        const isLow = p.currentStock <= p.minStockLevel;
        const stockClass = isLow ? 'bg-warning text-dark' : 'bg-success text-white';
        const cardBorder = isLow ? 'border-warning' : 'border-success';
        const { displayStock } = getDisplayStock(p);
        return `<div class="product-chip border ${cardBorder} rounded-3 p-2" style="cursor:pointer;min-width:140px;max-width:180px;flex:1"
            data-bidx="${idx}" onclick="addItemFromBrowser(${idx})">
            <div class="fw-semibold small text-truncate" title="${p.name}">${p.name}${p.litersPerPiece > 0 ? ` <span style="font-size:.65rem;background:#e0f2fe;color:#0369a1;padding:.1rem .35rem;border-radius:20px;font-weight:700">${p.litersPerPiece % 1 === 0 ? parseInt(p.litersPerPiece) : p.litersPerPiece}L</span>` : ''}</div>
            ${p.brand ? `<div class="text-muted" style="font-size:.7rem">${p.brand}</div>` : ''}
            <div class="d-flex justify-content-between align-items-center mt-1">
                <span class="badge ${stockClass} rounded-pill" style="font-size:.68rem">${displayStock}</span>
                <span class="text-primary fw-semibold" style="font-size:.75rem">${parseFloat(p.salePrice).toFixed(3)}</span>
            </div>
        </div>`;
    }).join('');
}

function addItemFromBrowser(idx) {
    const p = browserProducts[idx];
    if (!p) return;
    const ppu = p.piecesPerUnit || 0;
    const isCarton = (p.unit === 'كرتون' || p.unit === 'Carton') && ppu > 0;
    addItem({
        id: p.id,
        name: p.name,
        salePrice: p.salePrice,
        purchasePrice: p.purchasePrice,
        currentStock: isCarton ? p.currentStock * ppu : p.currentStock,
        unit: isCarton ? 'حبة' : p.unit,
        piecesPerUnit: ppu,
        isCarton
    });
}

function filterBrowser(q) {
    const base = allProducts.filter(p => p.currentStock > 0);
    const filtered = q
        ? base.filter(p => p.name.toLowerCase().includes(q.toLowerCase()) || (p.brand && p.brand.toLowerCase().includes(q.toLowerCase())))
        : base;
    renderProductBrowser(filtered);
}

function toggleProductBrowser() {
    const el = document.getElementById('productBrowser');
    const icon = document.getElementById('browserChevron');
    const hidden = el.style.display === 'none';
    el.style.display = hidden ? '' : 'none';
    icon.className = hidden ? 'bi bi-chevron-up' : 'bi bi-chevron-down';
}

const productSearch = document.getElementById('productSearch');
const productSuggestions = document.getElementById('productSuggestions');
let searchTimeout;

productSearch.addEventListener('input', () => {
    clearTimeout(searchTimeout);
    const q = productSearch.value.trim().toLowerCase();
    if (!q) { productSuggestions.classList.add('d-none'); return; }
    searchTimeout = setTimeout(() => {
        const filtered = allProducts.filter(p =>
            p.name.toLowerCase().includes(q) || (p.sku && p.sku.toLowerCase().includes(q))
        ).slice(0, 8);
        renderSuggestions(filtered);
    }, 150);
});

function renderSuggestions(products) {
    if (!products.length) { productSuggestions.classList.add('d-none'); return; }
    productSuggestions.innerHTML = products.map(p => {
        const { displayStock, displayUnit } = getDisplayStock(p);
        return `
        <div class="suggestion-item" data-id="${p.id}" data-name="${p.name}"
            data-price="${p.salePrice}" data-purchase="${p.purchasePrice}" data-stock="${p.currentStock}"
            data-unit="${p.unit}" data-pieces="${p.piecesPerUnit || 0}">
            <div>
                <div class="fw-semibold small">${p.name}${p.litersPerPiece > 0 ? ` <span style="font-size:.65rem;background:#e0f2fe;color:#0369a1;padding:.1rem .35rem;border-radius:20px;font-weight:700">${p.litersPerPiece % 1 === 0 ? parseInt(p.litersPerPiece) : p.litersPerPiece}L</span>` : ''}</div>
                <small class="text-muted">${displayUnit} | متوفر: ${displayStock}</small>
            </div>
            <span class="badge bg-primary-subtle text-primary">${parseFloat(p.salePrice).toFixed(3)} ر.ع.</span>
        </div>`;
    }).join('');
    productSuggestions.classList.remove('d-none');

    productSuggestions.querySelectorAll('.suggestion-item').forEach(el => {
        el.addEventListener('click', () => {
            const ppu = parseInt(el.dataset.pieces) || 0;
            const rawStock = parseInt(el.dataset.stock);
            const isCarton = (el.dataset.unit === 'كرتون' || el.dataset.unit === 'Carton') && ppu > 0;
            addItem({
                id: parseInt(el.dataset.id),
                name: el.dataset.name,
                salePrice: parseFloat(el.dataset.price),
                purchasePrice: parseFloat(el.dataset.purchase),
                currentStock: isCarton ? rawStock * ppu : rawStock,
                unit: isCarton ? 'حبة' : el.dataset.unit,
                piecesPerUnit: ppu,
                isCarton
            });
            productSearch.value = '';
            productSuggestions.classList.add('d-none');
        });
    });
}

document.addEventListener('click', e => {
    if (!productSearch.contains(e.target)) productSuggestions.classList.add('d-none');
});

function addItem(product) {
    const existing = invoiceItems.find(i => i.productId === product.id);
    if (existing) {
        if (existing.quantity >= product.currentStock) {
            showToast(`الكمية المتوفرة ${product.currentStock} فقط`, 'danger');
            return;
        }
        existing.quantity++;
        existing.total = existing.quantity * existing.unitPrice;
    } else {
        invoiceItems.push({
            productId: product.id,
            productName: product.name,
            quantity: 1,
            unitPrice: product.salePrice,
            purchasePrice: product.purchasePrice,
            total: product.salePrice,
            maxStock: product.currentStock,
            unit: product.unit
        });
    }
    renderItems();
    calcTotals(true);
}

function renderItems() {
    const tbody = document.getElementById('itemsBody');
    const emptyRow = document.getElementById('emptyRow');

    if (!invoiceItems.length) {
        tbody.innerHTML = `<tr id="emptyRow"><td colspan="5" class="text-center text-muted py-5">
            <i class="bi bi-cart-x fs-2 d-block mb-2"></i>ابحث عن منتج وأضفه للفاتورة</td></tr>`;
        document.getElementById('itemCount').textContent = '0 منتج';
        document.getElementById('saveInvoice').disabled = true;
        return;
    }

    tbody.innerHTML = invoiceItems.map((item, idx) => `
        <tr>
            <td>
                <div class="fw-semibold small">${item.productName}</div>
                <small class="text-muted">${item.unit}</small>
            </td>
            <td>
                <div class="input-group input-group-sm">
                    <button class="btn btn-outline-secondary" onclick="changeQty(${idx},-1)">-</button>
                    <input type="number" class="form-control text-center" value="${item.quantity}" min="1"
                        max="${item.maxStock}" onchange="setQty(${idx},this.value)" style="width:50px">
                    <button class="btn btn-outline-secondary" onclick="changeQty(${idx},1)">+</button>
                </div>
            </td>
            <td>
                <input type="number" class="form-control form-control-sm text-end" value="${item.unitPrice.toFixed(3)}"
                    min="0" step="0.01" onchange="setPrice(${idx},this.value)" style="width:100px">
            </td>
            <td class="fw-semibold text-primary">${item.total.toFixed(3)}</td>
            <td>
                <button class="btn btn-sm btn-outline-danger" onclick="removeItem(${idx})">
                    <i class="bi bi-trash3"></i>
                </button>
            </td>
        </tr>
    `).join('');

    document.getElementById('itemCount').textContent = `${invoiceItems.length} منتج`;
    document.getElementById('saveInvoice').disabled = false;
}

function changeQty(idx, delta) {
    const item = invoiceItems[idx];
    const newQty = item.quantity + delta;
    if (newQty < 1) return;
    if (newQty > item.maxStock) { showToast(`الكمية المتوفرة ${item.maxStock} فقط`, 'warning'); return; }
    item.quantity = newQty;
    item.total = newQty * item.unitPrice;
    renderItems();
    calcTotals(true);
}

function setQty(idx, val) {
    const qty = Math.max(1, Math.min(parseInt(val) || 1, invoiceItems[idx].maxStock));
    invoiceItems[idx].quantity = qty;
    invoiceItems[idx].total = qty * invoiceItems[idx].unitPrice;
    renderItems();
    calcTotals(true);
}

function setPrice(idx, val) {
    invoiceItems[idx].unitPrice = parseFloat(val) || 0;
    invoiceItems[idx].total = invoiceItems[idx].quantity * invoiceItems[idx].unitPrice;
    renderItems();
    calcTotals(true);
}

function removeItem(idx) {
    invoiceItems.splice(idx, 1);
    renderItems();
    calcTotals(true);
}

function calcTotals(fromItems = false) {
    if (fromItems) {
        const computed = invoiceItems.reduce((s, i) => s + i.total, 0);
        document.getElementById('subTotal').value = computed.toFixed(3);
    }
    const subTotal = parseFloat(document.getElementById('subTotal').value) || 0;
    const taxRate = parseFloat(document.getElementById('taxRate').value) || 0;
    const discount = parseFloat(document.getElementById('discount').value) || 0;
    const taxAmount = subTotal * (taxRate / 100);
    const total = subTotal + taxAmount - discount;

    document.getElementById('taxAmount').textContent = taxAmount.toFixed(3) + ' ر.ع.';
    document.getElementById('totalAmount').textContent = total.toFixed(3) + ' ر.ع.';
}

document.getElementById('subTotal').addEventListener('input', () => { calcTotals(false); updateSaveBtn(); });
document.getElementById('taxRate').addEventListener('input', () => calcTotals(false));
document.getElementById('discount').addEventListener('input', () => calcTotals(false));

function updateSaveBtn() {
    const hasItems = invoiceItems.length > 0;
    const hasManual = (parseFloat(document.getElementById('subTotal').value) || 0) > 0;
    document.getElementById('saveInvoice').disabled = !hasItems && !hasManual;
}

// Customer Search
const customerSearch = document.getElementById('customerSearch');
const customerSuggestions = document.getElementById('customerSuggestions');
let customerTimeout;

customerSearch.addEventListener('input', () => {
    clearTimeout(customerTimeout);
    const q = customerSearch.value.trim();
    if (!q) { customerSuggestions.classList.add('d-none'); return; }
    customerTimeout = setTimeout(async () => {
        const res = await fetch(`/Customers/Search?term=${encodeURIComponent(q)}`);
        const customers = await res.json();
        if (!customers.length) { customerSuggestions.classList.add('d-none'); return; }
        customerSuggestions.innerHTML = customers.map(c => `
            <div class="suggestion-item" data-id="${c.id}" data-name="${c.name}">
                <div>
                    <div class="fw-semibold small">${c.name}</div>
                    <small class="text-muted">${c.phone || ''} ${c.carModel ? '| ' + c.carModel : ''}</small>
                </div>
            </div>
        `).join('');
        customerSuggestions.classList.remove('d-none');
        customerSuggestions.querySelectorAll('.suggestion-item').forEach(el => {
            el.addEventListener('click', () => {
                document.getElementById('selectedCustomerId').value = el.dataset.id;
                customerSearch.value = el.dataset.name;
                customerSuggestions.classList.add('d-none');
                document.getElementById('selectedCustomerInfo').textContent = '✓ تم اختيار العميل';
                document.getElementById('selectedCustomerInfo').classList.remove('d-none');
            });
        });
    }, 250);
});

document.getElementById('clearCustomer').addEventListener('click', () => {
    customerSearch.value = '';
    document.getElementById('selectedCustomerId').value = '';
    document.getElementById('selectedCustomerInfo').classList.add('d-none');
    customerSuggestions.classList.add('d-none');
});

document.addEventListener('click', e => {
    if (!customerSearch.closest('.mb-3').contains(e.target))
        customerSuggestions.classList.add('d-none');
});

// Save Invoice
document.getElementById('saveInvoice').addEventListener('click', async () => {
    const manualSubTotalVal = parseFloat(document.getElementById('subTotal').value) || 0;
    if (!invoiceItems.length && manualSubTotalVal <= 0) return;
    const btn = document.getElementById('saveInvoice');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>جاري الحفظ...';

    const manualSubTotal = parseFloat(document.getElementById('subTotal').value) || 0;
    const taxRate = parseFloat(document.getElementById('taxRate').value) || 0;
    const discount = parseFloat(document.getElementById('discount').value) || 0;

    const payload = {
        customerId: document.getElementById('selectedCustomerId').value || null,
        invoiceDate: document.getElementById('invoiceDate').value,
        paymentMethod: parseInt(document.getElementById('paymentMethod').value),
        taxRate,
        discount,
        manualSubTotal,
        notes: document.getElementById('notes').value,
        items: invoiceItems.map(i => ({
            productId: i.productId,
            productName: i.productName,
            quantity: i.quantity,
            unitPrice: i.unitPrice,
            purchasePrice: i.purchasePrice,
            total: i.total
        }))
    };

    try {
        const res = await fetch('/Invoices/Create', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
            },
            body: JSON.stringify(payload)
        });
        const data = await res.json();
        if (res.ok) {
            window.location.href = `/Invoices/Print/${data.invoiceId}`;
        } else {
            showToast(data.message || 'حدث خطأ', 'danger');
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-save2 me-2"></i>حفظ الفاتورة';
        }
    } catch {
        showToast('خطأ في الاتصال', 'danger');
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-save2 me-2"></i>حفظ الفاتورة';
    }
});

function showToast(msg, type = 'info') {
    const container = document.createElement('div');
    container.className = `toast align-items-center text-bg-${type} border-0 show position-fixed`;
    container.style.cssText = 'top:20px;left:50%;transform:translateX(-50%);z-index:9999;min-width:280px';
    container.innerHTML = `<div class="d-flex"><div class="toast-body fw-semibold">${msg}</div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div>`;
    document.body.appendChild(container);
    setTimeout(() => container.remove(), 3500);
}
</script>
<form id="antiforgery" method="post">@Html.AntiForgeryToken()</form>
}
