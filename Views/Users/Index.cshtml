@model List<OilShopManagement.Controllers.UserWithRolesViewModel>
@using OilShopManagement.Authorization
@{
    ViewData["Title"] = "المستخدمون والصلاحيات";
    var stats = ViewBag.Stats as OilShopManagement.Controllers.UserStatsViewModel;
    var roles = ViewBag.Roles as List<string> ?? new List<string>();
    var permGroups = ViewBag.PermissionGroups as IEnumerable<PermissionGroup> ?? [];
    var currentUserId = ViewBag.CurrentUserId as string;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-shield-lock me-2 text-primary"></i>المستخدمون والصلاحيات</h4>
        <small class="text-muted">إدارة الحسابات وتخصيص الصلاحيات لكل مستخدم</small>
    </div>
    <button class="btn btn-primary rounded-pill px-4 shadow-sm" onclick="openAddModal()">
        <i class="bi bi-person-plus-fill me-2"></i>مستخدم جديد
    </button>
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
    @{
        var cards = new[] {
            ("إجمالي المستخدمين", stats?.Total ?? 0, "bi-people-fill", "primary"),
            ("مديرو النظام",       stats?.Admins ?? 0,    "bi-shield-fill",   "danger"),
            ("الموظفون",           stats?.Employees ?? 0, "bi-person-badge",  "info"),
            ("الحسابات النشطة",   stats?.Active ?? 0,    "bi-check-circle-fill","success"),
        };
    }
    @foreach (var (label, val, icon, color) in cards)
    {
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-3 d-flex align-items-center gap-3">
                    <div class="rounded-xl d-flex align-items-center justify-content-center bg-@color bg-opacity-10"
                        style="width:46px;height:46px;flex-shrink:0">
                        <i class="bi @icon text-@color fs-5"></i>
                    </div>
                    <div>
                        <div class="fs-4 fw-black text-@color lh-1">@val</div>
                        <div class="text-muted small mt-1">@label</div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Filters -->
<div class="card mb-3 border-0 shadow-sm">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-md-5">
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="search" class="form-control border-start-0 ps-0"
                        placeholder="بحث بالاسم أو البريد..." value="@ViewBag.Search">
                </div>
            </div>
            <div class="col-md-3">
                <select name="roleFilter" class="form-select form-select-sm">
                    <option value="">جميع الأدوار</option>
                    @foreach (var r in roles)
                    {
                        var rl = ViewBag.RoleFilter == r;
                        var lbl = r == "Admin" ? "مدير" : "موظف";
                        if (rl) { <option value="@r" selected>@lbl</option> }
                        else    { <option value="@r">@lbl</option> }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <select name="statusFilter" class="form-select form-select-sm">
                    <option value="">جميع الحالات</option>
                    @if (ViewBag.StatusFilter == "active")   { <option value="active" selected>نشط</option> }   else { <option value="active">نشط</option> }
                    @if (ViewBag.StatusFilter == "inactive") { <option value="inactive" selected>معطل</option> } else { <option value="inactive">معطل</option> }
                </select>
            </div>
            <div class="col-md-2 d-flex gap-1">
                <button type="submit" class="btn btn-primary btn-sm flex-fill rounded-pill">
                    <i class="bi bi-funnel me-1"></i>تصفية
                </button>
                <a href="/Users" class="btn btn-outline-secondary btn-sm rounded-pill px-2" title="مسح">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent d-flex align-items-center justify-content-between py-2">
        <span class="fw-semibold small">النتائج: <span class="badge bg-primary rounded-pill">@Model.Count</span></span>
        <span class="text-muted small d-none d-md-inline"><i class="bi bi-hand-index me-1"></i>انقر على مستخدم لإدارة صلاحياته</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:46px">#</th>
                        <th>المستخدم</th>
                        <th class="d-none d-md-table-cell">البريد</th>
                        <th>الدور</th>
                        <th class="d-none d-lg-table-cell">الصلاحيات</th>
                        <th class="d-none d-md-table-cell">آخر دخول</th>
                        <th>الحالة</th>
                        <th style="width:180px">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int i = 1; }
                    @foreach (var item in Model)
                    {
                        var isCurrent = item.User.Id == currentUserId;
                        var isAdmin = item.Roles.Contains("Admin");
                        var initials = string.Concat(item.User.FullName.Split(' ').Take(2).Select(s => s.Length > 0 ? s[0].ToString() : ""));
                        var aColor = isAdmin ? "#dc3545" : "#0d6efd";
                        var permCount = isAdmin ? Permissions.All.Count() : item.Permissions.Count;

                        <tr class="@(!item.User.IsActive ? "opacity-50" : "")">
                            <td class="text-muted small ps-3">@(i++)</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold flex-shrink-0"
                                        style="width:38px;height:38px;background:@aColor;font-size:0.78rem">
                                        @initials.ToUpper()
                                    </div>
                                    <div>
                                        <div class="fw-semibold small lh-1">
                                            @item.User.FullName
                                            @if (isCurrent)
                                            { <span class="badge bg-warning text-dark ms-1" style="font-size:0.58rem;vertical-align:middle">أنت</span> }
                                        </div>
                                        <div class="text-muted d-md-none" style="font-size:0.72rem">@item.User.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td class="small text-muted d-none d-md-table-cell">@item.User.Email</td>
                            <td>
                                @if (isAdmin)
                                {
                                    <span class="badge d-inline-flex align-items-center gap-1 px-2 py-1"
                                        style="background:rgba(220,53,69,0.12);color:#dc3545;border:1px solid rgba(220,53,69,0.25);border-radius:20px">
                                        <i class="bi bi-shield-fill" style="font-size:0.65rem"></i>مدير
                                    </span>
                                }
                                else
                                {
                                    <span class="badge d-inline-flex align-items-center gap-1 px-2 py-1"
                                        style="background:rgba(13,110,253,0.1);color:#0d6efd;border:1px solid rgba(13,110,253,0.2);border-radius:20px">
                                        <i class="bi bi-person-badge" style="font-size:0.65rem"></i>موظف
                                    </span>
                                }
                            </td>
                            <td class="d-none d-lg-table-cell">
                                @if (isAdmin)
                                {
                                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill">
                                        <i class="bi bi-infinity me-1"></i>كاملة
                                    </span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill @(permCount == 0 ? "bg-secondary-subtle text-secondary" : "bg-primary-subtle text-primary") border @(permCount == 0 ? "border-secondary-subtle" : "border-primary-subtle")"
                                        style="cursor:pointer"
                                        onclick="openPermissionsModal('@item.User.Id','@item.User.FullName')">
                                        <i class="bi bi-key me-1"></i>@permCount صلاحية
                                    </span>
                                }
                            </td>
                            <td class="small d-none d-md-table-cell">
                                @if (item.User.LastLoginAt.HasValue)
                                { <span class="text-muted">@GetTimeAgo(item.User.LastLoginAt.Value)</span> }
                                else
                                { <span class="text-muted opacity-50">—</span> }
                            </td>
                            <td>
                                @if (item.User.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle d-inline-flex align-items-center gap-1 rounded-pill">
                                        <span class="rounded-circle bg-success" style="width:5px;height:5px"></span>نشط
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary border d-inline-flex align-items-center gap-1 rounded-pill">
                                        <span class="rounded-circle bg-secondary" style="width:5px;height:5px"></span>معطل
                                    </span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-1 flex-wrap">
                                    <!-- صلاحيات -->
                                    @if (!isAdmin)
                                    {
                                        <button class="btn btn-sm btn-outline-warning rounded-pill px-2" title="الصلاحيات"
                                            onclick="openPermissionsModal('@item.User.Id','@item.User.FullName')">
                                            <i class="bi bi-key-fill"></i>
                                        </button>
                                    }
                                    <!-- تعديل -->
                                    <button class="btn btn-sm btn-outline-primary rounded-pill px-2" title="تعديل"
                                        onclick="openEditModal('@item.User.Id','@item.User.FullName','@item.User.Email','@(item.Roles.FirstOrDefault()??"")')">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    <!-- كلمة المرور -->
                                    <button class="btn btn-sm btn-outline-secondary rounded-pill px-2" title="كلمة المرور"
                                        onclick="openResetModal('@item.User.Id','@item.User.FullName')">
                                        <i class="bi bi-lock-fill"></i>
                                    </button>
                                    <!-- تفعيل/تعطيل -->
                                    @if (!isCurrent)
                                    {
                                        <form asp-action="ToggleActive" asp-route-id="@item.User.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" title="@(item.User.IsActive ? "تعطيل" : "تفعيل")"
                                                class="btn btn-sm @(item.User.IsActive ? "btn-outline-danger" : "btn-outline-success") rounded-pill px-2">
                                                <i class="bi @(item.User.IsActive ? "bi-person-dash" : "bi-person-check")"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="8" class="text-center text-muted py-5">
                            <i class="bi bi-people fs-1 d-block mb-2 opacity-25"></i>لا يوجد مستخدمون
                        </td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Permission Groups Reference -->
<div class="card mt-4 border-0" style="background:var(--bs-tertiary-bg)">
    <div class="card-body pb-2">
        <h6 class="fw-bold mb-3"><i class="bi bi-grid-3x3-gap text-primary me-2"></i>مرجع الصلاحيات المتاحة</h6>
        <div class="row g-2">
            @foreach (var g in permGroups)
            {
                <div class="col-md-4 col-lg-2">
                    <div class="card border-0 bg-@g.Color bg-opacity-10 h-100">
                        <div class="card-body p-2">
                            <div class="d-flex align-items-center gap-1 mb-1">
                                <i class="bi @g.Icon text-@g.Color small"></i>
                                <span class="fw-semibold small text-@g.Color">@g.Label</span>
                            </div>
                            @foreach (var item in g.Items)
                            {
                                <div class="text-muted" style="font-size:0.72rem">• @item.Label</div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>


<!-- ══════════════ MODALS ══════════════ -->

<!-- Add User Modal -->
<div class="modal fade" id="addUserModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-0 pb-0">
                <div class="d-flex align-items-center gap-2">
                    <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white" style="width:38px;height:38px">
                        <i class="bi bi-person-plus-fill"></i>
                    </div>
                    <h5 class="modal-title fw-bold mb-0">إضافة مستخدم جديد</h5>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Create" method="post" id="addUserForm">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">الاسم الكامل <span class="text-danger">*</span></label>
                            <input type="text" name="fullName" class="form-control" placeholder="مثال: أحمد محمد" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">البريد الإلكتروني <span class="text-danger">*</span></label>
                            <input type="email" name="email" class="form-control" placeholder="user@example.com" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">كلمة المرور <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input type="password" name="password" id="addPwd" class="form-control" required minlength="6" placeholder="••••••••">
                                <button type="button" class="btn btn-outline-secondary" onclick="togglePwd('addPwd','addPwdEye')">
                                    <i class="bi bi-eye" id="addPwdEye"></i>
                                </button>
                            </div>
                            <div class="form-text small">6 أحرف كحد أدنى</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">الدور <span class="text-danger">*</span></label>
                            <div class="d-flex gap-2">
                                <div class="flex-fill">
                                    <input type="radio" class="btn-check" name="role" id="addRoleEmp" value="Employee" checked onchange="onRoleChange()">
                                    <label class="btn btn-outline-primary w-100" for="addRoleEmp">
                                        <i class="bi bi-person-badge me-1"></i>موظف
                                    </label>
                                </div>
                                <div class="flex-fill">
                                    <input type="radio" class="btn-check" name="role" id="addRoleAdmin" value="Admin" onchange="onRoleChange()">
                                    <label class="btn btn-outline-danger w-100" for="addRoleAdmin">
                                        <i class="bi bi-shield-fill me-1"></i>مدير
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Permissions Section -->
                    <div id="permissionsSection">
                        <hr class="my-2">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <span class="fw-semibold small"><i class="bi bi-key-fill text-warning me-1"></i>الصلاحيات</span>
                            <div class="d-flex gap-1">
                                <button type="button" class="btn btn-xs btn-outline-success rounded-pill px-2 py-0" onclick="checkAll(true)" style="font-size:0.75rem">تحديد الكل</button>
                                <button type="button" class="btn btn-xs btn-outline-secondary rounded-pill px-2 py-0" onclick="checkAll(false)" style="font-size:0.75rem">إلغاء الكل</button>
                                <button type="button" class="btn btn-xs btn-outline-primary rounded-pill px-2 py-0" onclick="setDefaults()" style="font-size:0.75rem">الافتراضية</button>
                            </div>
                        </div>
                        <div class="row g-2">
                            @foreach (var g in permGroups)
                            {
                                <div class="col-md-4">
                                    <div class="card border-0 bg-@g.Color bg-opacity-10">
                                        <div class="card-body p-2">
                                            <div class="d-flex align-items-center justify-content-between mb-1">
                                                <span class="fw-semibold small text-@g.Color">
                                                    <i class="bi @g.Icon me-1"></i>@g.Label
                                                </span>
                                                <button type="button" class="btn-link text-muted p-0 border-0 bg-transparent"
                                                    style="font-size:0.7rem" onclick="checkGroup('@g.Label', true)">تحديد</button>
                                            </div>
                                            @foreach (var pitem in g.Items)
                                            {
                                                var isDefault = Permissions.EmployeeDefaults.Contains(pitem.Value);
                                                <div class="form-check mb-0">
                                                    <input class="form-check-input perm-check" type="checkbox"
                                                        name="permissions" value="@pitem.Value"
                                                        id="add_@pitem.Value.Replace('.','_')"
                                                        data-group="@g.Label"
                                                        @(isDefault ? "checked" : "")>
                                                    <label class="form-check-label" style="font-size:0.78rem"
                                                        for="add_@pitem.Value.Replace('.','_')">@pitem.Label</label>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="mt-2 text-muted small">
                            <i class="bi bi-info-circle me-1"></i>الصلاحيات تنطبق فقط على حساب <strong>موظف</strong>. المدير يملك كافة الصلاحيات تلقائياً.
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">
                        <i class="bi bi-person-check-fill me-2"></i>إنشاء الحساب
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit User Modal -->
<div class="modal fade" id="editUserModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-0 pb-0">
                <div class="d-flex align-items-center gap-2">
                    <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white" style="width:38px;height:38px">
                        <i class="bi bi-pencil-square"></i>
                    </div>
                    <h5 class="modal-title fw-bold mb-0">تعديل بيانات المستخدم</h5>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="editId">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">الاسم الكامل</label>
                        <input type="text" name="fullName" id="editName" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">البريد الإلكتروني</label>
                        <input type="email" name="email" id="editEmail" class="form-control" required>
                    </div>
                    <div>
                        <label class="form-label fw-semibold small">الدور</label>
                        <div class="d-flex gap-2">
                            <div class="flex-fill">
                                <input type="radio" class="btn-check" name="role" id="editRoleEmp" value="Employee">
                                <label class="btn btn-outline-primary w-100" for="editRoleEmp">
                                    <i class="bi bi-person-badge me-1"></i>موظف
                                </label>
                            </div>
                            <div class="flex-fill">
                                <input type="radio" class="btn-check" name="role" id="editRoleAdmin" value="Admin">
                                <label class="btn btn-outline-danger w-100" for="editRoleAdmin">
                                    <i class="bi bi-shield-fill me-1"></i>مدير
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">
                        <i class="bi bi-save2 me-2"></i>حفظ
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Permissions Modal -->
<div class="modal fade" id="permissionsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-0 pb-0">
                <div class="d-flex align-items-center gap-2">
                    <div class="rounded-circle bg-warning d-flex align-items-center justify-content-center text-dark" style="width:38px;height:38px">
                        <i class="bi bi-key-fill fs-6"></i>
                    </div>
                    <div>
                        <h5 class="modal-title fw-bold mb-0">إدارة الصلاحيات</h5>
                        <small class="text-muted" id="permModalUser"></small>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="SavePermissions" method="post" id="permForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="permUserId">
                <div class="modal-body pt-2">
                    <div class="d-flex align-items-center justify-content-between mb-3 p-2 rounded" style="background:var(--bs-tertiary-bg)">
                        <span class="small text-muted"><i class="bi bi-info-circle me-1"></i>اختر الصلاحيات المناسبة للمستخدم</span>
                        <div class="d-flex gap-1">
                            <button type="button" class="btn btn-sm btn-success rounded-pill px-3" onclick="permCheckAll(true)">
                                <i class="bi bi-check-all me-1"></i>تحديد الكل
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill px-3" onclick="permCheckAll(false)">
                                <i class="bi bi-x me-1"></i>إلغاء الكل
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-primary rounded-pill px-3" onclick="permSetDefaults()">
                                <i class="bi bi-stars me-1"></i>الافتراضية
                            </button>
                        </div>
                    </div>

                    <div class="row g-3" id="permGroupsContainer">
                        @foreach (var g in permGroups)
                        {
                            <div class="col-md-4">
                                <div class="card h-100 border-0 shadow-sm">
                                    <div class="card-header bg-@g.Color bg-opacity-10 border-0 py-2">
                                        <div class="d-flex align-items-center justify-content-between">
                                            <span class="fw-bold small text-@g.Color">
                                                <i class="bi @g.Icon me-1"></i>@g.Label
                                            </span>
                                            <div class="form-check mb-0">
                                                <input class="form-check-input group-check" type="checkbox"
                                                    id="groupAll_@g.Label" onchange="toggleGroup('@g.Label', this.checked)"
                                                    title="تحديد مجموعة @g.Label">
                                            </div>
                                        </div>
                                    </div>
                                    <div class="card-body p-3">
                                        @foreach (var pitem in g.Items)
                                        {
                                            <div class="form-check mb-2">
                                                <input class="form-check-input perm-modal-check" type="checkbox"
                                                    name="permissions" value="@pitem.Value"
                                                    id="perm_@pitem.Value.Replace('.','_')"
                                                    data-group="@g.Label"
                                                    onchange="updateGroupCheck('@g.Label')">
                                                <label class="form-check-label small fw-medium"
                                                    for="perm_@pitem.Value.Replace('.','_')">@pitem.Label</label>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="mt-3 p-2 rounded border border-primary-subtle bg-primary-subtle">
                        <small class="text-primary fw-semibold">
                            <i class="bi bi-shield-check me-1"></i>
                            الصلاحيات المحددة: <span id="permCount" class="fw-black">0</span>
                            من أصل <strong>@Permissions.All.Count()</strong>
                        </small>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-warning rounded-pill px-4 text-dark fw-semibold">
                        <i class="bi bi-save2 me-2"></i>حفظ الصلاحيات
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Reset Password Modal -->
<div class="modal fade" id="resetModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-0 pb-0">
                <div class="d-flex align-items-center gap-2">
                    <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center text-white" style="width:38px;height:38px">
                        <i class="bi bi-lock-fill"></i>
                    </div>
                    <h5 class="modal-title fw-bold mb-0">تغيير كلمة المرور</h5>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="ResetPassword" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body pt-2">
                    <p class="small text-muted mb-3">المستخدم: <strong id="resetName"></strong></p>
                    <input type="hidden" name="id" id="resetId">
                    <div class="input-group">
                        <input type="password" name="newPassword" id="resetPwd" class="form-control" required minlength="6" placeholder="كلمة مرور جديدة">
                        <button type="button" class="btn btn-outline-secondary" onclick="togglePwd('resetPwd','resetEye')">
                            <i class="bi bi-eye" id="resetEye"></i>
                        </button>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-dark rounded-pill fw-semibold">
                        <i class="bi bi-lock me-1"></i>تغيير
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>


@section Scripts {
<script>
// ─── Modal openers ───────────────────────────────────────
function openAddModal() {
    document.getElementById('addUserForm').reset();
    document.querySelectorAll('.perm-check').forEach(cb => {
        cb.checked = cb.dataset.default === 'true';
    });
    setDefaults();
    onRoleChange();
    new bootstrap.Modal(document.getElementById('addUserModal')).show();
}

function openEditModal(id, name, email, role) {
    document.getElementById('editId').value = id;
    document.getElementById('editName').value = name;
    document.getElementById('editEmail').value = email;
    document.getElementById('editRoleEmp').checked   = role !== 'Admin';
    document.getElementById('editRoleAdmin').checked = role === 'Admin';
    new bootstrap.Modal(document.getElementById('editUserModal')).show();
}

async function openPermissionsModal(id, name) {
    document.getElementById('permUserId').value = id;
    document.getElementById('permModalUser').textContent = name;

    // جلب صلاحيات المستخدم الحالية
    try {
        const res = await fetch(`/Users/GetUserPermissions?id=${id}`);
        const data = await res.json();
        const userPerms = data.permissions || [];

        document.querySelectorAll('.perm-modal-check').forEach(cb => {
            cb.checked = userPerms.includes(cb.value);
        });

        // تحديث checkboxes المجموعات
        document.querySelectorAll('.perm-modal-check').forEach(cb => {
            updateGroupCheck(cb.dataset.group);
        });

        updatePermCount();
    } catch {}

    new bootstrap.Modal(document.getElementById('permissionsModal')).show();
}

function openResetModal(id, name) {
    document.getElementById('resetId').value = id;
    document.getElementById('resetName').textContent = name;
    document.getElementById('resetPwd').value = '';
    new bootstrap.Modal(document.getElementById('resetModal')).show();
}

// ─── Permissions helpers ──────────────────────────────────
const defaults = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Permissions.EmployeeDefaults));

function setDefaults() {
    document.querySelectorAll('.perm-check').forEach(cb => {
        cb.checked = defaults.includes(cb.value);
    });
}

function checkAll(val) {
    document.querySelectorAll('.perm-check').forEach(cb => cb.checked = val);
}

function checkGroup(group, val) {
    document.querySelectorAll(`.perm-check[data-group="${group}"]`).forEach(cb => cb.checked = val);
}

function permCheckAll(val) {
    document.querySelectorAll('.perm-modal-check').forEach(cb => cb.checked = val);
    document.querySelectorAll('.group-check').forEach(cb => cb.checked = val);
    updatePermCount();
}

function permSetDefaults() {
    document.querySelectorAll('.perm-modal-check').forEach(cb => {
        cb.checked = defaults.includes(cb.value);
    });
    document.querySelectorAll('.perm-modal-check').forEach(cb => updateGroupCheck(cb.dataset.group));
    updatePermCount();
}

function toggleGroup(group, val) {
    document.querySelectorAll(`.perm-modal-check[data-group="${group}"]`).forEach(cb => cb.checked = val);
    updatePermCount();
}

function updateGroupCheck(group) {
    const all  = [...document.querySelectorAll(`.perm-modal-check[data-group="${group}"]`)];
    const gCb  = document.getElementById(`groupAll_${group}`);
    if (!gCb) return;
    const checked = all.filter(cb => cb.checked).length;
    gCb.checked = checked === all.length;
    gCb.indeterminate = checked > 0 && checked < all.length;
    updatePermCount();
}

function updatePermCount() {
    const count = document.querySelectorAll('.perm-modal-check:checked').length;
    document.getElementById('permCount').textContent = count;
}

// ─── Role change → show/hide permissions ─────────────────
function onRoleChange() {
    const isAdmin = document.getElementById('addRoleAdmin').checked;
    document.getElementById('permissionsSection').style.opacity = isAdmin ? '0.4' : '1';
    document.getElementById('permissionsSection').style.pointerEvents = isAdmin ? 'none' : 'auto';
}

// ─── Password toggle ──────────────────────────────────────
function togglePwd(inputId, eyeId) {
    const el = document.getElementById(inputId);
    const ic = document.getElementById(eyeId);
    el.type = el.type === 'password' ? 'text' : 'password';
    ic.className = el.type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash';
}
</script>
}

@functions {
    string GetTimeAgo(DateTime dt) {
        var d = DateTime.Now - dt;
        if (d.TotalMinutes < 1)  return "الآن";
        if (d.TotalHours   < 1)  return $"منذ {(int)d.TotalMinutes} دقيقة";
        if (d.TotalDays    < 1)  return $"منذ {(int)d.TotalHours} ساعة";
        if (d.TotalDays    < 30) return $"منذ {(int)d.TotalDays} يوم";
        if (d.TotalDays   < 365) return $"منذ {(int)(d.TotalDays/30)} شهر";
        return $"منذ {(int)(d.TotalDays/365)} سنة";
    }
}
