<!DOCTYPE html>
<html lang="@L.Lang" dir="@L.Dir" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @L.T("نظام إدارة زيوت السيارات","Auto Oil Shop")</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="@L.BootstrapCss">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="wrapper">
        <nav id="sidebar" class="sidebar">
            <div class="sidebar-header">
                <div class="brand-logo">
                    <i class="bi bi-droplet-fill text-warning fs-3"></i>
                    <span class="brand-name">@L.T("زيوت السيارات","Auto Oil")</span>
                </div>
            </div>
            <ul class="sidebar-menu">
                <li class="menu-item">
                    <a href="/Dashboard" class="menu-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                        <i class="bi bi-speedometer2"></i><span>@L.T("لوحة التحكم","Dashboard")</span>
                    </a>
                </li>
                <li class="menu-section-title">@L.T("المخزون والمنتجات","Inventory")</li>
                <li class="menu-item">
                    <a href="/Products" class="menu-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Products" ? "active" : "")">
                        <i class="bi bi-box-seam"></i><span>@L.T("المنتجات","Products")</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="/Categories" class="menu-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Categories" ? "active" : "")">
                        <i class="bi bi-tags"></i><span>@L.T("التصنيفات","Categories")</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="/Stock" class="menu-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Stock" ? "active" : "")">
                        <i class="bi bi-arrow-left-right"></i><span>@L.T("حركة المخزون","Stock Movement")</span>
                    </a>
                </li>
                <li class="menu-section-title">@L.T("المبيعات","Sales")</li>
                <li class="menu-item">
                    <a href="/Invoices/Create" class="menu-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Invoices" && ViewContext.RouteData.Values["action"]?.ToString() == "Create" ? "active" : "")">
                        <i class="bi bi-plus-circle"></i><span>@L.T("مبيعات جديدة","New Sale")</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="/Invoices" class="menu-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Invoices" && ViewContext.RouteData.Values["action"]?.ToString() != "Create" ? "active" : "")">
                        <i class="bi bi-receipt"></i><span>@L.T("فواتير المبيعات","Sales Invoices")</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="/Customers" class="menu-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Customers" ? "active" : "")">
                        <i class="bi bi-people"></i><span>@L.T("العملاء","Customers")</span>
                    </a>
                </li>
                <li class="menu-section-title">@L.T("المشتريات","Purchases")</li>
                <li class="menu-item">
                    <a href="/Purchases/Create" class="menu-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Purchases" && ViewContext.RouteData.Values["action"]?.ToString() == "Create" ? "active" : "")">
                        <i class="bi bi-cart-plus"></i><span>@L.T("مشتريات جديدة","New Purchase")</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="/Purchases" class="menu-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Purchases" && ViewContext.RouteData.Values["action"]?.ToString() != "Create" ? "active" : "")">
                        <i class="bi bi-bag-check"></i><span>@L.T("فواتير المشتريات","Purchase Invoices")</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="/Suppliers" class="menu-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Suppliers" ? "active" : "")">
                        <i class="bi bi-truck"></i><span>@L.T("الموردون","Suppliers")</span>
                    </a>
                </li>
                <li class="menu-section-title">@L.T("المرتجعات","Returns")</li>
                <li class="menu-item">
                    <a href="/SaleReturns" class="menu-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "SaleReturns" ? "active" : "")">
                        <i class="bi bi-arrow-return-left"></i><span>@L.T("مرتجعات المبيعات","Sale Returns")</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="/PurchaseReturns" class="menu-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "PurchaseReturns" ? "active" : "")">
                        <i class="bi bi-arrow-return-right"></i><span>@L.T("مرتجعات المشتريات","Purchase Returns")</span>
                    </a>
                </li>
                <li class="menu-section-title">@L.T("التقارير","Reports")</li>
                <li class="menu-item">
                    <a href="/Reports/Sales" class="menu-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" && ViewContext.RouteData.Values["action"]?.ToString() == "Sales" ? "active" : "")">
                        <i class="bi bi-bar-chart"></i><span>@L.T("تقرير المبيعات","Sales Report")</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="/Reports/Stock" class="menu-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" && ViewContext.RouteData.Values["action"]?.ToString() == "Stock" ? "active" : "")">
                        <i class="bi bi-clipboard-data"></i><span>@L.T("تقرير المخزون","Stock Report")</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="/Reports/TopProducts" class="menu-link">
                        <i class="bi bi-trophy"></i><span>@L.T("الأكثر مبيعاً","Top Selling")</span>
                    </a>
                </li>
                @if (User.IsInRole("Admin"))
                {
                    <li class="menu-section-title">@L.T("الإدارة","Administration")</li>
                    <li class="menu-item">
                        <a href="/Users" class="menu-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")">
                            <i class="bi bi-person-gear"></i><span>@L.T("المستخدمين","Users")</span>
                        </a>
                    </li>
                }
            </ul>
        </nav>

        <div class="main-content" id="mainContent">
            <nav class="top-navbar">
                <div class="d-flex align-items-center gap-3">
                    <button class="btn btn-link text-body p-0" id="sidebarToggle">
                        <i class="bi bi-list fs-4"></i>
                    </button>
                    <span class="fw-semibold d-none d-md-inline">@ViewData["Title"]</span>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <!-- Language Switcher -->
                    <div class="btn-group btn-group-sm">
                        <a href="/Account/SetLanguage?culture=ar-SA&returnUrl=@Context.Request.Path"
                           class="btn @(L.IsAr ? "btn-primary" : "btn-outline-secondary") rounded-start-pill px-2">ع</a>
                        <a href="/Account/SetLanguage?culture=en-US&returnUrl=@Context.Request.Path"
                           class="btn @(!L.IsAr ? "btn-primary" : "btn-outline-secondary") rounded-end-pill px-2">EN</a>
                    </div>
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Users/Create" class="btn btn-sm btn-success rounded-pill px-3">
                            <i class="bi bi-person-plus-fill me-1"></i>@L.T("مستخدم جديد","New User")
                        </a>
                    }
                    <button class="btn btn-sm btn-outline-secondary rounded-pill px-3" id="darkModeToggle" title="@L.T("الوضع الداكن","Dark Mode")">
                        <i class="bi bi-moon-stars-fill"></i>
                    </button>
                    <div class="dropdown">
                        <button class="btn btn-primary btn-sm rounded-pill px-3 dropdown-toggle" data-bs-toggle="dropdown">
                            <i class="bi bi-person-fill me-1"></i>@User.Identity!.Name
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow">
                            <li class="dropdown-item-text small text-muted">
                                @L.T("تسجيل الدخول كـ","Signed in as") @(User.IsInRole("Admin") ? L.T("مدير","Admin") : L.T("موظف","Employee"))
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="bi bi-box-arrow-right me-2"></i>@L.T("تسجيل الخروج","Logout")
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>

            <div class="page-content">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </div>
        </div>
    </div>
}
else
{
    @RenderBody()
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
