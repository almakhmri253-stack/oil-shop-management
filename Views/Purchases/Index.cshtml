@model IEnumerable<OilShopManagement.Models.Purchase>
@{
    ViewData["Title"] = "فواتير الشراء";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-bag-check me-2 text-success"></i>فواتير الشراء</h4>
    <a href="/Purchases/Create" class="btn btn-success rounded-pill px-4">
        <i class="bi bi-plus-circle me-2"></i>مشتريات جديدة
    </a>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-semibold">من تاريخ</label>
                <input type="date" name="from" class="form-control" value="@ViewBag.From">
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">إلى تاريخ</label>
                <input type="date" name="to" class="form-control" value="@ViewBag.To">
            </div>
            <div class="col-md-4">
                <label class="form-label small fw-semibold">بحث</label>
                <input type="text" name="search" class="form-control" placeholder="رقم الفاتورة أو اسم المورد..." value="@ViewBag.Search">
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-success w-100">
                    <i class="bi bi-search me-1"></i>بحث
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between">
        <span>النتائج: @Model.Count() فاتورة</span>
        <span class="fw-bold text-success">الإجمالي: @Model.Where(p => p.Status == OilShopManagement.Models.PurchaseStatus.Completed).Sum(p => p.TotalAmount).ToString("N3") ر.ع.</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>رقم الفاتورة</th>
                        <th>المورد</th>
                        <th>التاريخ</th>
                        <th>طريقة الدفع</th>
                        <th>الإجمالي</th>
                        <th>الحالة</th>
                        <th>إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td><span class="badge bg-success-subtle text-success fw-semibold">@p.PurchaseNumber</span></td>
                            <td>@(p.Supplier?.Name ?? "مورد عام")</td>
                            <td>@p.PurchaseDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if (p.PaymentMethod == OilShopManagement.Models.PaymentMethod.Cash)
                                { <span class="badge bg-success-subtle text-success"><i class="bi bi-cash me-1"></i>نقداً</span> }
                                else if (p.PaymentMethod == OilShopManagement.Models.PaymentMethod.Card)
                                { <span class="badge bg-info-subtle text-info"><i class="bi bi-credit-card me-1"></i>بطاقة</span> }
                                else
                                { <span class="badge bg-warning-subtle text-warning"><i class="bi bi-bank me-1"></i>تحويل</span> }
                            </td>
                            <td class="fw-semibold">@p.TotalAmount.ToString("N3") ر.ع.</td>
                            <td>
                                @if (p.Status == OilShopManagement.Models.PurchaseStatus.Completed)
                                { <span class="badge bg-success">مكتملة</span> }
                                else if (p.Status == OilShopManagement.Models.PurchaseStatus.Cancelled)
                                { <span class="badge bg-danger">ملغاة</span> }
                                else
                                { <span class="badge bg-secondary">مسودة</span> }
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a href="/Purchases/Details/@p.Id" class="btn btn-outline-secondary rounded-start-pill" title="تفاصيل">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a href="/Purchases/Print/@p.Id" class="btn btn-outline-success rounded-end-pill" target="_blank" title="طباعة">
                                        <i class="bi bi-printer"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-5">
                            <i class="bi bi-inbox fs-2 d-block mb-2"></i>لا توجد فواتير شراء في هذه الفترة
                        </td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
