@model OilShopManagement.Models.Product
@{
    ViewData["Title"] = L.T("تعديل المنتج","Edit Product");
}

<style>
    .img-upload-box {
        border: 2px dashed #cbd5e1; border-radius: 14px;
        padding: 1.5rem; text-align: center; cursor: pointer;
        transition: .2s; background: #f8fafc; position: relative;
    }
    .img-upload-box:hover { border-color: #0d6efd; background: #f0f7ff; }
    .img-upload-box.has-img { border-style: solid; border-color: #0d6efd; padding: .5rem; }
    .img-preview { width:100%; max-height:180px; object-fit:contain; border-radius:10px; }
</style>

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="/Products" class="btn btn-outline-secondary rounded-circle"
       style="width:38px;height:38px;padding:0;display:flex;align-items:center;justify-content:center">
        <i class="bi bi-arrow-@(L.IsAr ? "right" : "left")"></i>
    </a>
    <h4 class="fw-bold mb-0"><i class="bi bi-pencil-fill me-2 text-primary"></i>@L.T("تعديل","Edit"): @Model.Name</h4>
</div>

<div class="card border-0 shadow-sm" style="max-width:760px">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden">
            <input asp-for="CurrentStock" type="hidden">
            <input asp-for="CreatedAt" type="hidden">
            <input asp-for="ImagePath" type="hidden">
            <div class="row g-3">

                <!-- Image upload -->
                <div class="col-12">
                    <label class="form-label fw-semibold small">@L.T("صورة المنتج","Product Image")</label>
                    <div class="img-upload-box @(!string.IsNullOrEmpty(Model.ImagePath) ? "has-img" : "")"
                         id="uploadBox" onclick="document.getElementById('imageFile').click()">
                        @if (!string.IsNullOrEmpty(Model.ImagePath))
                        {
                            <img id="imgPreview" class="img-preview" src="@Model.ImagePath" alt="@Model.Name">
                            <div class="text-muted small mt-1" id="imgPlaceholder" style="display:none">
                                <i class="bi bi-image fs-2 d-block mb-1"></i>
                                @L.T("انقر لتغيير الصورة","Click to change image")
                            </div>
                        }
                        else
                        {
                            <img id="imgPreview" class="img-preview" src="#" alt="preview" style="display:none">
                            <div class="img-placeholder" id="imgPlaceholder">
                                <i class="bi bi-image fs-2 text-muted d-block mb-1"></i>
                                <div class="small text-muted">@L.T("انقر لاختيار صورة","Click to select image")</div>
                                <div class="text-muted" style="font-size:.72rem">JPG, PNG, WEBP</div>
                            </div>
                        }
                        <input type="file" name="imageFile" id="imageFile" accept=".jpg,.jpeg,.png,.webp"
                               class="d-none" onchange="previewImg(this)">
                    </div>
                </div>

                <div class="col-md-8">
                    <label asp-for="Name" class="form-label fw-semibold small"></label>
                    <input asp-for="Name" class="form-control">
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="SKU" class="form-label fw-semibold small"></label>
                    <input asp-for="SKU" class="form-control">
                </div>
                <div class="col-md-6">
                    <label asp-for="Brand" class="form-label fw-semibold small"></label>
                    <input asp-for="Brand" class="form-control" placeholder="@L.T("مثال: موبيل، شل، كاسترول","e.g. Mobil, Shell, Castrol")">
                </div>
                <div class="col-md-6">
                    <label asp-for="CategoryId" class="form-label fw-semibold small"></label>
                    <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                        <option value="">@L.T("-- اختر التصنيف --","-- Select Category --")</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Unit" class="form-label fw-semibold small"></label>
                    <select asp-for="Unit" class="form-select" id="unitSelect" onchange="togglePieces(this.value)">
                        <option>@L.T("قطعة","Piece")</option>
                        <option>@L.T("لتر","Liter")</option>
                        <option>@L.T("كيلو","Kg")</option>
                        <option>@L.T("علبة","Box")</option>
                        <option>@L.T("جالون","Gallon")</option>
                        <option>@L.T("كرتون","Carton")</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label asp-for="LitersPerPiece" class="form-label fw-semibold small"></label>
                    <div class="input-group">
                        <input asp-for="LitersPerPiece" class="form-control" type="number" step="0.01" min="0"
                               placeholder="@L.T("مثال: 4","e.g. 4")">
                        <span class="input-group-text small">@L.T("لتر","L")</span>
                    </div>
                </div>
                <div class="col-md-2" id="piecesPerUnitDiv">
                    <label asp-for="PiecesPerUnit" class="form-label fw-semibold small"></label>
                    <input asp-for="PiecesPerUnit" class="form-control" type="number" min="1" placeholder="@L.T("عدد الحبات","Pieces")">
                </div>
                <div class="col-md-4">
                    <label asp-for="PurchasePrice" class="form-label fw-semibold small"></label>
                    <div class="input-group">
                        <input asp-for="PurchasePrice" class="form-control" type="number" step="0.001" min="0">
                        <span class="input-group-text">@L.T("ر.ع.","OMR")</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <label asp-for="SalePrice" class="form-label fw-semibold small"></label>
                    <div class="input-group">
                        <input asp-for="SalePrice" class="form-control" type="number" step="0.001" min="0">
                        <span class="input-group-text">@L.T("ر.ع.","OMR")</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <label asp-for="MinStockLevel" class="form-label fw-semibold small"></label>
                    <input asp-for="MinStockLevel" class="form-control" type="number" min="0">
                </div>
                <div class="col-12">
                    <label asp-for="Description" class="form-label fw-semibold small"></label>
                    <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4 rounded-pill">
                        <i class="bi bi-save2 me-2"></i>@L.T("حفظ التعديلات","Save Changes")
                    </button>
                    <a href="/Products" class="btn btn-outline-secondary rounded-pill">@L.T("إلغاء","Cancel")</a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
    function togglePieces(val) {
        const div = document.getElementById('piecesPerUnitDiv');
        div.style.display = (val === 'كرتون' || val === 'Carton') ? '' : 'none';
    }
    togglePieces(document.getElementById('unitSelect').value);

    function previewImg(input) {
        if (!input.files || !input.files[0]) return;
        const reader = new FileReader();
        reader.onload = e => {
            const box = document.getElementById('uploadBox');
            const preview = document.getElementById('imgPreview');
            const placeholder = document.getElementById('imgPlaceholder');
            preview.src = e.target.result;
            preview.style.display = 'block';
            if (placeholder) placeholder.style.display = 'none';
            box.classList.add('has-img');
        };
        reader.readAsDataURL(input.files[0]);
    }
    </script>
}
