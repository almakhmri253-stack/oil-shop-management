@model IEnumerable<OilShopManagement.Models.Product>
@using OilShopManagement.Models
@{
    ViewData["Title"] = L.T("المنتجات","Products");
    var allCategories  = ViewBag.AllCategories as List<Category> ?? new();
    var selectedCatId  = ViewBag.CategoryId as int?;
    var search         = ViewBag.Search as string ?? "";

    var totalProducts  = Model.Count();
    var inStock        = Model.Count(p => p.CurrentStock > p.MinStockLevel);
    var lowStock       = Model.Count(p => p.IsLowStock && p.CurrentStock > 0);
    var outOfStock     = Model.Count(p => p.CurrentStock == 0);
    var totalValue     = Model.Sum(p => p.CurrentStock * p.PurchasePrice);

    string LiterColor(decimal? l) {
        if (!l.HasValue || l <= 0) return "#0369a1";
        if (l <= 1m)  return "#0d9488";   // teal  — small (≤1L)
        if (l <= 3m)  return "#0369a1";   // blue  — medium (2–3L)
        return "#4338ca";                  // indigo — large (4L+)
    }

    string[] CatColors = { "#0d6efd","#f97316","#10b981","#8b5cf6","#ef4444","#0891b2","#d97706","#db2777" };
    string CatColor(int i) => CatColors[i % CatColors.Length];
    // returns: (imgPath or null, fallback bootstrap-icon class)
    (string? img, string icon) CatIcon(string n) {
        var v = n.ToLower();
        if (v.Contains("محرك")||v.Contains("engine"))
            return ("/images/categories/engine-oil.svg", "bi-droplet-fill");
        if (v.Contains("جير")||v.Contains("قير")||v.Contains("gear")||v.Contains("ناقل"))
            return ("/images/categories/gear-oil.svg",   "bi-arrow-repeat");
        if (v.Contains("فلتر")||v.Contains("filter"))
            return ("/images/categories/filter.svg",     "bi-funnel-fill");
        if (v.Contains("هيدرو")||v.Contains("hydro"))
            return (null, "bi-water");
        if (v.Contains("قطعة")||v.Contains("part")||v.Contains("اكسسوار"))
            return (null, "bi-wrench-adjustable");
        return (null, "bi-droplet-fill");
    }
}

<style>
/* KPI cards */
.kpi-card { border-radius:16px; padding:1.1rem 1.3rem; border:none; transition:.2s; }
.kpi-card:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(0,0,0,.1); }
.kpi-icon { width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.3rem; }

/* Category pills */
.cat-pill { border:2px solid #e2e8f0; border-radius:50px; padding:.35rem 1rem; cursor:pointer;
    font-size:.82rem; font-weight:600; text-decoration:none; color:#64748b; background:#fff;
    transition:.15s; white-space:nowrap; display:inline-flex; align-items:center; gap:.4rem; }
.cat-pill:hover { border-color:var(--cc); color:var(--cc); background:color-mix(in srgb,var(--cc) 8%,white); }
.cat-pill.active { border-color:var(--cc); background:var(--cc); color:#fff; }

/* Product cards */
.pcard { border-radius:16px; border:1.5px solid #e9ecef; background:#fff;
    transition:.2s; overflow:hidden; display:flex; flex-direction:column; }
.pcard:hover { border-color:#0d6efd33; box-shadow:0 8px 28px rgba(13,110,253,.1); transform:translateY(-2px); }
.pcard.low-stock { border-color:#fbbf24; }
.pcard.out-stock { border-color:#f87171; background:#fff8f8; }
.pcard-img { width:100%; height:110px; object-fit:contain; background:#f8fafc; padding:.5rem; }
.pcard-no-img { width:100%;height:110px;display:flex;align-items:center;justify-content:center;font-size:2.2rem;background:#f8fafc; }
.pcard-body { padding:.9rem; flex:1; }
.pcard-footer { padding:.5rem .9rem; border-top:1px solid #f1f5f9; display:flex; gap:.4rem; }

/* Stock badge */
.stock-badge { border-radius:50px; padding:.2rem .65rem; font-size:.7rem; font-weight:700; }

/* Quick action buttons */
.qbtn { border-radius:8px; font-size:.72rem; font-weight:600; padding:.3rem .6rem; border:1.5px solid; transition:.15s; }
.qbtn:hover { transform:translateY(-1px); }

/* Search */
.search-bar { border-radius:50px; border:2px solid #e2e8f0; padding:.4rem 1rem; font-size:.88rem; }
.search-bar:focus { border-color:#0d6efd; outline:none; box-shadow:0 0 0 3px rgba(13,110,253,.1); }

/* Liter size ribbon overlaid on card image */
.pcard-img-wrap { position:relative; }
.liter-ribbon {
    position:absolute; top:8px; right:8px; z-index:2;
    color:#fff; font-weight:900; font-size:1.05rem; line-height:1.2;
    border-radius:10px; padding:.18rem .58rem;
    box-shadow:0 2px 8px rgba(0,0,0,.22);
    letter-spacing:-.3px; white-space:nowrap;
}
</style>

<!-- ── Header ── -->
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-boxes me-2 text-primary"></i>@L.T("إدارة المنتجات","Products")</h4>
        <small class="text-muted">@totalProducts @L.T("منتج في المخزون","products in inventory")</small>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <a href="/Products/Create" class="btn btn-primary rounded-pill px-4 fw-semibold">
            <i class="bi bi-plus-lg me-1"></i>@L.T("منتج جديد","New Product")
        </a>
    }
</div>

<!-- ── KPI Row ── -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="kpi-card" style="background:linear-gradient(135deg,#eff6ff,#dbeafe)">
            <div class="d-flex align-items-center gap-3">
                <div class="kpi-icon" style="background:#bfdbfe;color:#1d4ed8"><i class="bi bi-boxes"></i></div>
                <div>
                    <div class="fw-black fs-4 lh-1 text-primary">@totalProducts</div>
                    <div class="small text-muted mt-1">@L.T("إجمالي المنتجات","Total Products")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="kpi-card" style="background:linear-gradient(135deg,#f0fdf4,#dcfce7)">
            <div class="d-flex align-items-center gap-3">
                <div class="kpi-icon" style="background:#bbf7d0;color:#15803d"><i class="bi bi-check-circle-fill"></i></div>
                <div>
                    <div class="fw-black fs-4 lh-1 text-success">@inStock</div>
                    <div class="small text-muted mt-1">@L.T("متوفر","In Stock")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="kpi-card" style="background:linear-gradient(135deg,#fffbeb,#fef3c7)">
            <div class="d-flex align-items-center gap-3">
                <div class="kpi-icon" style="background:#fde68a;color:#b45309"><i class="bi bi-exclamation-triangle-fill"></i></div>
                <div>
                    <div class="fw-black fs-4 lh-1 text-warning">@lowStock</div>
                    <div class="small text-muted mt-1">@L.T("مخزون منخفض","Low Stock")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="kpi-card" style="background:linear-gradient(135deg,#fef2f2,#fee2e2)">
            <div class="d-flex align-items-center gap-3">
                <div class="kpi-icon" style="background:#fecaca;color:#b91c1c"><i class="bi bi-x-circle-fill"></i></div>
                <div>
                    <div class="fw-black fs-4 lh-1 text-danger">@outOfStock</div>
                    <div class="small text-muted mt-1">@L.T("نفد المخزون","Out of Stock")</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── Quick Links ── -->
<div class="d-flex flex-wrap gap-2 mb-4">
    <a href="/Purchases/Create" class="btn btn-outline-success rounded-pill btn-sm fw-semibold px-3">
        <i class="bi bi-cart-plus me-1"></i>@L.T("فاتورة شراء جديدة","New Purchase")
    </a>
    <a href="/Invoices/Create" class="btn btn-outline-primary rounded-pill btn-sm fw-semibold px-3">
        <i class="bi bi-receipt me-1"></i>@L.T("فاتورة بيع جديدة","New Sale")
    </a>
    <a href="/Products?lowStock=1" class="btn btn-outline-warning rounded-pill btn-sm fw-semibold px-3">
        <i class="bi bi-exclamation-triangle me-1"></i>@L.T("المخزون المنخفض","Low Stock") (@lowStock)
    </a>
    <div class="ms-auto text-muted small d-flex align-items-center">
        <i class="bi bi-wallet2 me-1"></i>@L.T("قيمة المخزون","Stock Value"):
        <span class="fw-bold text-dark ms-1">@totalValue.ToString("N3") @L.T("ر.ع.","OMR")</span>
    </div>
</div>

<!-- ── Search + Category Filter ── -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <form method="get" class="d-flex flex-wrap gap-2 align-items-center">
            @if (selectedCatId.HasValue)
            {
                <input type="hidden" name="categoryId" value="@selectedCatId">
            }
            <div class="input-group" style="max-width:320px">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" name="search" class="form-control border-start-0 ps-0"
                       placeholder="@L.T("بحث بالاسم أو الرمز أو العلامة...","Search name, SKU, brand...")"
                       value="@search" style="border-radius:0 50px 50px 0">
            </div>
            <button type="submit" class="btn btn-primary rounded-pill px-4">@L.T("بحث","Search")</button>
            @if (!string.IsNullOrEmpty(search) || selectedCatId.HasValue)
            {
                <a href="/Products" class="btn btn-outline-secondary rounded-pill px-3">
                    <i class="bi bi-x-circle me-1"></i>@L.T("مسح","Clear")
                </a>
            }
        </form>
    </div>
</div>

<!-- ── Category Pills ── -->
@if (allCategories.Any())
{
    <div class="d-flex flex-wrap gap-2 mb-4 align-items-center">
        <a href="/Products@(!string.IsNullOrEmpty(search) ? "?search=" + Uri.EscapeDataString(search) : "")"
           class="cat-pill @(!selectedCatId.HasValue ? "active" : "")"
           style="--cc:#0d6efd">
            <i class="bi bi-grid-fill"></i>@L.T("الكل","All") <span class="badge rounded-pill @(!selectedCatId.HasValue ? "bg-white text-primary" : "bg-secondary")">@totalProducts</span>
        </a>
        @{ int ci = 0; }
        @foreach (var cat in allCategories)
        {
            var cc = CatColor(ci);
            var (icoImg, icoClass) = CatIcon(cat.Name);
            var cnt = Model.Count(p => p.CategoryId == cat.Id);
            var isAct = selectedCatId == cat.Id;
            <a href="/Products?categoryId=@cat.Id@(!string.IsNullOrEmpty(search) ? "&search=" + Uri.EscapeDataString(search) : "")"
               class="cat-pill @(isAct ? "active" : "")" style="--cc:@cc">
                @if (icoImg != null)
                {
                    <img src="@icoImg" style="width:18px;height:18px;object-fit:contain" alt="">
                }
                else
                {
                    <i class="bi @icoClass"></i>
                }
                @cat.Name
                <span class="badge rounded-pill @(isAct ? "bg-white" : "bg-light text-dark")" style="@(isAct ? "color:" + cc : "")">@cnt</span>
            </a>
            ci++;
        }
    </div>
}

<!-- ── Products Grid ── -->
@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-inbox fs-1 d-block mb-3"></i>
        <div class="mb-3">@L.T("لا توجد منتجات","No products found")</div>
        @if (User.IsInRole("Admin"))
        {
            <a href="/Products/Create" class="btn btn-primary rounded-pill px-4">
                <i class="bi bi-plus-circle me-2"></i>@L.T("إضافة أول منتج","Add First Product")
            </a>
        }
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var p in Model)
        {
            var pidx   = allCategories.FindIndex(c => c.Id == p.CategoryId);
            var pcolor = pidx >= 0 ? CatColor(pidx) : "#0d6efd";
            var (piconImg, piconClass) = CatIcon(p.Category?.Name ?? "");

            bool isCarton = (p.Unit == "كرتون" || p.Unit == "Carton") && p.PiecesPerUnit.HasValue && p.PiecesPerUnit > 0;
            int dispStock = isCarton ? p.CurrentStock * p.PiecesPerUnit!.Value : p.CurrentStock;
            string dispUnit = isCarton ? "حبة" : p.Unit;

            string cardClass = p.CurrentStock == 0 ? "out-stock" : (p.IsLowStock ? "low-stock" : "");
            string stockBadgeClass = p.CurrentStock == 0 ? "bg-danger text-white"
                                   : p.IsLowStock ? "bg-warning text-dark"
                                   : "bg-success text-white";
            string stockLabel = p.CurrentStock == 0 ? L.T("نفد","Out")
                              : p.IsLowStock ? L.T("منخفض","Low")
                              : L.T("متوفر","In Stock");

            int pct = p.MinStockLevel > 0 ? (int)Math.Min(100, dispStock * 100.0 / (p.MinStockLevel * (isCarton ? p.PiecesPerUnit!.Value : 1) * 3)) : 100;
            string barColor = p.CurrentStock == 0 ? "bg-danger" : p.IsLowStock ? "bg-warning" : "bg-success";

            <div class="col-sm-6 col-lg-4 col-xl-3">
                <div class="pcard h-100 @cardClass">
                    <!-- Image / Icon -->
                    <div class="pcard-img-wrap">
                        @if (p.LitersPerPiece.HasValue && p.LitersPerPiece > 0)
                        {
                            var lbl2 = p.LitersPerPiece % 1 == 0
                                ? ((int)p.LitersPerPiece).ToString() + "L"
                                : p.LitersPerPiece?.ToString("N2") + "L";
                            <span class="liter-ribbon" style="background:@LiterColor(p.LitersPerPiece)">@lbl2</span>
                        }
                        @if (!string.IsNullOrEmpty(p.ImagePath))
                        {
                            <img src="@p.ImagePath" alt="@p.Name" class="pcard-img">
                        }
                        else
                        {
                            <div class="pcard-no-img" style="background:#f8fafc">
                                @if (piconImg != null)
                                {
                                    <img src="@piconImg" style="width:80px;height:80px;object-fit:contain" alt="@p.Category?.Name">
                                }
                                else
                                {
                                    <i class="bi @piconClass" style="font-size:2.8rem;color:@pcolor"></i>
                                }
                            </div>
                        }
                    </div>

                    <div class="pcard-body">
                        <!-- Category + Stock status -->
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="badge rounded-pill fw-normal" style="background:color-mix(in srgb,@pcolor 12%,white);color:@pcolor;font-size:.68rem">
                                @p.Category?.Name
                            </span>
                            <span class="stock-badge @stockBadgeClass">@stockLabel</span>
                        </div>

                        <!-- Name & Brand -->
                        <div class="d-flex align-items-start gap-1 flex-wrap">
                            <h6 class="fw-bold mb-0 lh-sm">@p.Name</h6>
                            @if (p.LitersPerPiece.HasValue && p.LitersPerPiece > 0)
                            {
                                var lbl = p.LitersPerPiece % 1 == 0
                                    ? ((int)p.LitersPerPiece).ToString() + "L"
                                    : p.LitersPerPiece?.ToString("N2") + "L";
                                <span class="badge rounded-pill fw-bold flex-shrink-0"
                                      style="background:@LiterColor(p.LitersPerPiece);color:#fff;font-size:.72rem;margin-top:2px">@lbl</span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(p.Brand))
                        {
                            <div class="text-muted small mb-1" style="font-size:.75rem">
                                <i class="bi bi-building me-1"></i>@p.Brand
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(p.SKU))
                        {
                            <div class="text-muted mb-2" style="font-size:.7rem">
                                <i class="bi bi-upc me-1"></i>@p.SKU
                            </div>
                        }

                        <!-- Stock bar -->
                        <div class="d-flex justify-content-between align-items-center mb-1 mt-2">
                            <span class="text-muted" style="font-size:.72rem">@L.T("المخزون","Stock")</span>
                            <span class="fw-bold small @(p.CurrentStock == 0 ? "text-danger" : p.IsLowStock ? "text-warning" : "text-success")">
                                @dispStock @dispUnit
                                @if (isCarton)
                                {
                                    <span class="text-muted fw-normal" style="font-size:.68rem">(‎@p.CurrentStock @L.T("كرتون","carton"))</span>
                                }
                            </span>
                        </div>
                        <div class="progress mb-3" style="height:5px;border-radius:3px">
                            <div class="progress-bar @barColor" style="width:@pct%"></div>
                        </div>

                        <!-- Prices -->
                        <div class="row g-2 text-center mb-2">
                            <div class="col-6">
                                <div class="rounded-3 p-2" style="background:#f8fafc">
                                    <div class="fw-bold" style="font-size:.85rem;color:@pcolor">@p.SalePrice.ToString("N3")</div>
                                    <div class="text-muted" style="font-size:.63rem">@L.T("سعر البيع","Sale") ر.ع.</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="rounded-3 p-2 bg-light">
                                    <div class="fw-bold text-secondary" style="font-size:.85rem">@p.PurchasePrice.ToString("N3")</div>
                                    <div class="text-muted" style="font-size:.63rem">@L.T("سعر الشراء","Cost") ر.ع.</div>
                                </div>
                            </div>
                        </div>

                        @if (isCarton && p.CartonSalePrice.HasValue)
                        {
                            <div class="rounded-3 p-2 text-center mb-2" style="background:color-mix(in srgb,@pcolor 6%,white);border:1px solid color-mix(in srgb,@pcolor 20%,white)">
                                <div class="fw-bold" style="font-size:.78rem;color:@pcolor">
                                    @p.CartonSalePrice?.ToString("N3") ر.ع. / @L.T("كرتون","carton")
                                </div>
                                <div class="text-muted" style="font-size:.63rem">@p.PiecesPerUnit @L.T("حبة في الكرتون","pcs per carton")</div>
                            </div>
                        }

                        <!-- Profit margin -->
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted" style="font-size:.72rem">@L.T("هامش الربح","Margin")</span>
                            <span class="fw-semibold small text-primary">@p.ProfitMargin.ToString("N1")%</span>
                        </div>
                    </div>

                    <!-- Footer Actions -->
                    <div class="pcard-footer">
                        <!-- Quick: add stock (purchase) -->
                        <a href="/Purchases/Create" title="@L.T("إضافة مخزون (شراء)","Add Stock via Purchase")"
                           class="qbtn text-success border-success flex-fill text-center text-decoration-none">
                            <i class="bi bi-cart-plus"></i> @L.T("شراء","Buy")
                        </a>
                        <!-- Quick: sell -->
                        <a href="/Invoices/Create" title="@L.T("بيع هذا المنتج","Sell this product")"
                           class="qbtn text-primary border-primary flex-fill text-center text-decoration-none">
                            <i class="bi bi-receipt"></i> @L.T("بيع","Sell")
                        </a>
                        <!-- Details -->
                        <a href="/Products/Details/@p.Id" title="@L.T("تفاصيل","Details")"
                           class="qbtn text-secondary border-secondary flex-fill text-center text-decoration-none">
                            <i class="bi bi-eye"></i>
                        </a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a href="/Products/Edit/@p.Id" title="@L.T("تعديل","Edit")"
                               class="qbtn text-warning border-warning flex-fill text-center text-decoration-none">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@p.Id" method="post" style="flex:1"
                                  onsubmit="return confirm('@L.T("حذف المنتج؟","Delete product?")')">
                                @Html.AntiForgeryToken()
                                <button type="submit" title="@L.T("حذف","Delete")"
                                        class="qbtn text-danger border-danger w-100">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }

        @* Add new product card *@
        @if (User.IsInRole("Admin"))
        {
            <div class="col-sm-6 col-lg-4 col-xl-3">
                <a href="/Products/Create@(selectedCatId.HasValue ? "?catId=" + selectedCatId : "")"
                   class="text-decoration-none h-100 d-block">
                    <div class="pcard h-100 d-flex flex-column align-items-center justify-content-center"
                         style="min-height:260px;border:2.5px dashed #cbd5e1;background:#f8fafc;cursor:pointer"
                         onmouseover="this.style.borderColor='#0d6efd';this.style.background='#eff6ff'"
                         onmouseout="this.style.borderColor='#cbd5e1';this.style.background='#f8fafc'">
                        <div class="rounded-circle d-flex align-items-center justify-content-center mb-3"
                             style="width:60px;height:60px;background:#dbeafe;color:#0d6efd;font-size:1.7rem">
                            <i class="bi bi-plus-lg"></i>
                        </div>
                        <div class="fw-bold text-primary">@L.T("إضافة منتج جديد","Add New Product")</div>
                        <div class="text-muted small mt-1">@L.T("انقر للإضافة","Click to add")</div>
                    </div>
                </a>
            </div>
        }
    </div>
}
