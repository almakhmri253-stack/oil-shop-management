@model OilShopManagement.Models.Product
@{
    ViewData["Title"] = "تفاصيل المنتج";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="/Products" class="btn btn-outline-secondary rounded-circle" style="width:38px;height:38px;padding:0;display:flex;align-items:center;justify-content:center">
        <i class="bi bi-arrow-right"></i>
    </a>
    <h4 class="fw-bold mb-0">@Model.Name</h4>
    @if (Model.IsLowStock)
    {
        <span class="badge bg-warning text-dark"><i class="bi bi-exclamation-triangle me-1"></i>مخزون منخفض</span>
    }
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-body text-center">
                <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width:80px;height:80px">
                    <i class="bi bi-droplet-fill text-primary" style="font-size:2rem"></i>
                </div>
                <h5 class="fw-bold">@Model.Name</h5>
                <span class="badge bg-secondary">@Model.Category?.Name</span>
                @if (!string.IsNullOrEmpty(Model.SKU))
                {
                    <div class="text-muted small mt-1">@Model.SKU</div>
                }
            </div>
        </div>
        <div class="card">
            <div class="card-body">
                <div class="row g-2 text-center">
                    <div class="col-4">
                        <div class="bg-primary bg-opacity-10 rounded p-2">
                            <div class="fw-bold text-primary fs-4">@Model.CurrentStock</div>
                            <div class="text-muted" style="font-size:0.7rem">@Model.Unit</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="bg-light rounded p-2">
                            <div class="fw-bold">@Model.PurchasePrice.ToString("N3")</div>
                            <div class="text-muted" style="font-size:0.7rem">شراء</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="bg-success bg-opacity-10 rounded p-2">
                            <div class="fw-bold text-success">@Model.SalePrice.ToString("N3")</div>
                            <div class="text-muted" style="font-size:0.7rem">بيع</div>
                        </div>
                    </div>
                </div>
                <div class="mt-3 text-center">
                    <small class="text-muted">هامش الربح: <strong class="text-success">@Model.ProfitMargin.ToString("N1")%</strong></small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card">
            <div class="card-header fw-bold">
                <i class="bi bi-clock-history me-2"></i>حركات المخزون
            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>النوع</th>
                            <th class="text-center">الكمية</th>
                            <th class="text-center">قبل</th>
                            <th class="text-center">بعد</th>
                            <th>التاريخ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.Transactions is List<OilShopManagement.Models.StockTransaction> transactions)
                        {
                            @foreach (var t in transactions)
                            {
                                <tr>
                                    <td>
                                        @switch (t.Type)
                                        {
                                            case OilShopManagement.Models.TransactionType.Purchase:
                                                <span class="badge bg-success">شراء</span>
                                                break;
                                            case OilShopManagement.Models.TransactionType.Sale:
                                                <span class="badge bg-primary">بيع</span>
                                                break;
                                            default:
                                                <span class="badge bg-secondary">أخرى</span>
                                                break;
                                        }
                                    </td>
                                    <td class="text-center fw-bold @(t.Type == OilShopManagement.Models.TransactionType.Sale ? "text-danger" : "text-success")">
                                        @(t.Type == OilShopManagement.Models.TransactionType.Sale ? "-" : "+")@t.Quantity
                                    </td>
                                    <td class="text-center">@t.QuantityBefore</td>
                                    <td class="text-center fw-semibold">@t.QuantityAfter</td>
                                    <td class="small">@t.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
