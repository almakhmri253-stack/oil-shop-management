@model IEnumerable<OilShopManagement.Models.Supplier>
@{
    ViewData["Title"] = "الموردون";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h4 class="fw-bold mb-0"><i class="bi bi-truck me-2 text-primary"></i>الموردون</h4>
    <a href="/Suppliers/Create" class="btn btn-primary rounded-pill btn-sm">
        <i class="bi bi-plus-lg me-1"></i>مورد جديد
    </a>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="d-flex gap-2">
            <input type="text" name="search" value="@ViewBag.Search" class="form-control form-control-sm"
                placeholder="ابحث باسم المورد أو الهاتف...">
            <button class="btn btn-outline-primary btn-sm px-3">بحث</button>
            @if (!string.IsNullOrEmpty(ViewBag.Search as string))
            {
                <a href="/Suppliers" class="btn btn-outline-secondary btn-sm">مسح</a>
            }
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>اسم المورد</th>
                        <th>الهاتف</th>
                        <th>جهة الاتصال</th>
                        <th>البريد الإلكتروني</th>
                        <th>تاريخ الإضافة</th>
                        <th style="width:120px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@s.Name</td>
                            <td>@(s.Phone ?? "-")</td>
                            <td>@(s.ContactPerson ?? "-")</td>
                            <td>@(s.Email ?? "-")</td>
                            <td class="text-muted small">@s.CreatedAt.ToString("yyyy/MM/dd")</td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a href="/Suppliers/Edit/@s.Id" class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form method="post" action="/Suppliers/Delete/@s.Id"
                                        onsubmit="return confirm('حذف المورد @s.Name؟')">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-5">
                                <i class="bi bi-truck fs-2 d-block mb-2"></i>لا يوجد موردون
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
