@model OilShopManagement.Models.Supplier
@{
    ViewData["Title"] = L.T("تعديل المورد","Edit Supplier");
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h4 class="fw-bold mb-0"><i class="bi bi-truck me-2 text-primary"></i>@L.T("تعديل المورد","Edit Supplier")</h4>
    <a href="/Suppliers" class="btn btn-outline-secondary rounded-pill btn-sm">
        <i class="bi bi-arrow-right me-1"></i>@L.T("الموردون","Suppliers")
    </a>
</div>

<div class="card" style="max-width:600px">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id">
            <input type="hidden" asp-for="CreatedAt">
            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control">
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label asp-for="Phone" class="form-label fw-semibold"></label>
                    <input asp-for="Phone" class="form-control">
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label fw-semibold"></label>
                    <input asp-for="Email" class="form-control">
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="ContactPerson" class="form-label fw-semibold"></label>
                <input asp-for="ContactPerson" class="form-control">
            </div>
            <div class="mb-3">
                <label asp-for="Address" class="form-label fw-semibold"></label>
                <textarea asp-for="Address" class="form-control" rows="2"></textarea>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary rounded-pill px-4">
                    <i class="bi bi-save2 me-1"></i>@L.T("حفظ التعديلات","Save Changes")
                </button>
                <a href="/Suppliers" class="btn btn-outline-secondary rounded-pill px-4">@L.T("إلغاء","Cancel")</a>
            </div>
        </form>
    </div>
</div>
