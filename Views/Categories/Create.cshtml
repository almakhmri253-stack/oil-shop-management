@model OilShopManagement.Models.Category
@{
    ViewData["Title"] = L.T("تصنيف جديد","New Category");
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="/Categories" class="btn btn-outline-secondary rounded-circle" style="width:38px;height:38px;padding:0;display:flex;align-items:center;justify-content:center">
        <i class="bi bi-arrow-right"></i>
    </a>
    <h4 class="fw-bold mb-0">@L.T("إضافة تصنيف جديد","Add New Category")</h4>
</div>

<div class="card" style="max-width:500px">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control">
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="Description" class="form-label fw-semibold"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4 rounded-pill">
                    <i class="bi bi-save2 me-2"></i>@L.T("حفظ","Save")
                </button>
                <a href="/Categories" class="btn btn-outline-secondary rounded-pill">@L.T("إلغاء","Cancel")</a>
            </div>
        </form>
    </div>
</div>
