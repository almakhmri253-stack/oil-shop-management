@model IEnumerable<OilShopManagement.Models.Category>
@{
    ViewData["Title"] = L.T("التصنيفات","Categories");
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-tags me-2 text-primary"></i>@L.T("التصنيفات","Categories")</h4>
    <a href="/Categories/Create" class="btn btn-primary rounded-pill px-4">
        <i class="bi bi-plus-circle me-2"></i>@L.T("تصنيف جديد","New Category")
    </a>
</div>

<div class="row g-3">
    @foreach (var cat in Model)
    {
        <div class="col-md-4 col-lg-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="rounded-circle bg-primary bg-opacity-10 p-2">
                            <i class="bi bi-tag-fill text-primary"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-0">@cat.Name</h6>
                            @if (!cat.IsActive)
                            {
                                <span class="badge bg-secondary small">@L.T("معطل","Inactive")</span>
                            }
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(cat.Description))
                    {
                        <p class="text-muted small mb-3">@cat.Description</p>
                    }
                </div>
                <div class="card-footer bg-transparent d-flex gap-1 p-2">
                    <a href="/Categories/Edit/@cat.Id" class="btn btn-sm btn-outline-primary flex-fill">
                        <i class="bi bi-pencil me-1"></i>@L.T("تعديل","Edit")
                    </a>
                    <form asp-action="Delete" asp-route-id="@cat.Id" method="post" style="flex:1"
                        onsubmit="return confirm('@L.T("حذف التصنيف؟","Delete category?")')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger w-100">
                            <i class="bi bi-trash3"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>
